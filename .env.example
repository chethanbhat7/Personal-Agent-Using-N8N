# ------------------------------------------------------------------------------
# n8n Personal Assistant - Environment Variables Template
# Copy this file to '.env' and configure your values.
# ------------------------------------------------------------------------------

# n8n Instance Configuration
GENERIC_TIMEZONE=UTC
N8N_ENCRYPTION_KEY=your_secure_encryption_key_here
N8N_PROTOCOL=http
N8N_HOST=localhost
N8N_PORT=5678

# Groq API Configuration (for Llama 3.3 70B Chat Model)
GROQ_API_KEY=your_groq_api_key_here

# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Google Workspace (Sheets, Gmail, Calendar) OAuth Credentials
# Note: In self-hosted n8n, these are typically configured via the n8n UI, 
# but can also be defined globally.
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Search/Research API (used by the Research Agent if using Serper/Google)
SERPER_API_KEY=your_serper_api_key_here
